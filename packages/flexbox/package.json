{
  "name": "@motion-system/flexbox",
  "version": "4.0.6",
  "description": "Responsive React grid system built with Styled System, with support for Emotion and Styled Components",
  "main": "dist/index.js",
  "keywords": [
    "reflexbox",
    "flexbox",
    "grid-styled",
    "framer-motion",
    "layout",
    "emotion",
    "css",
    "style"
  ],
  "scripts": {
    "prepare": "babel src -d dist && yarn styled-components",
    "styled-components": "NODE_ENV=styled babel src -d styled-components"
  },
  "dependencies": {
    "@emotion/core": "^10.0.0",
    "@emotion/styled": "^10.0.0",
    "@styled-system/css": "^5.0.0",
    "@styled-system/should-forward-prop": "^5.0.0",
    "framer-motion": "^3.10.2",
    "styled-system": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.6"
  },
  "author": "Q, Brent Jackson",
  "repository": "motion-system/motion-system",
  "devDependencies": {
    "babel-plugin-transform-rename-import": "^2.3.0"
  }
}
